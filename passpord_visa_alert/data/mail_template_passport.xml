<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="email_template_passport_expiry" model="mail.template">
        <field name="name">Passport Expiry Alert</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="subject">Passport Expiry Alert - ${object.name}</field>
        <field name="email_from">${user.email_formatted}</field>
        <field name="body_html">
            <![CDATA[

            <p>Dear User,</p>

            <p>
                Employee
                <strong>${object.name}</strong>
                passport will expire on
                <strong>${object.passport_expire}</strong>.
            </p>

            <p>
                Please take the necessary action.
            </p>

            ]]>
        </field>
    </record> 
</odoo>