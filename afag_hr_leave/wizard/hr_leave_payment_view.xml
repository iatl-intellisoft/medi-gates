<odoo>
    <record id="view_leave_payment_form" model="ir.ui.view">
        <field name="name">leave.payment.form</field>
        <field name="model">hr.leave.payment</field>
        <field name="arch" type="xml">
            <form string="Leave Payment">
                <group>
                    <field name="journal_id" required="1"/>
                    <field name="debit_account_id"/>
                    <field name="credit_account_id"/>
                    <field name="is_purchased" widget="boolean_toggle" />
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
