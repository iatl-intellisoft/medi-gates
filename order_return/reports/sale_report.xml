<odoo>
    <data>

        <record id="sale_report_posted_view_tree2" model="ir.ui.view">
        <field name="name">sale.report.posted.list</field>
        <field name="model">sale.report.posted</field>
        <field name="arch" type="xml">
            <list string="Sales Analysis Report By Posted Invoice" action="action_open_order" type="object">
                <field name="date"/>
                <field name="invoice_date"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="product_id"/>
                <field name="product_uom_qty" sum="Total Qty Ordered"/>
                <field name="qty_invoiced" sum="Total Qty Invoiced"/>
                <field name="price_unit"/>
                <field name="price_subtotal" sum="Untaxed Total"/>
                <field name="price_total" sum="Total"/>
                <field name="line_invoice_status"/>
            </list>
        </field>
    </record>

    <record id="sale_report_posted_view_search2" model="ir.ui.view">
        <field name="name">sale.report.posted.search</field>
        <field name="model">sale.report.posted</field>
        <field name="arch" type="xml">
            <search string="Search Posted Sales">

            <field name="partner_id"/>
            <field name="user_id"/>
            <field name="team_id"/>
            <field name="product_id"/>
            <field name="line_invoice_status"/>

            <!-- Simple Filters -->

            <filter string="Fully Invoiced"
                    name="fully_invoiced"
                    domain="[('line_invoice_status','=','invoiced')]"/>

            <filter string="Draft Orders"
                    name="draft_orders"
                    domain="[('state','=','draft')]"/>

            <!-- Group By -->

            <group expand="0" string="Group By">
                <filter string="Customer"
                        name="group_partner"
                        context="{'group_by': 'partner_id'}"/>

                <filter string="Salesperson"
                        name="group_user"
                        context="{'group_by': 'user_id'}"/>

                <filter string="Sales Team"
                        name="group_team"
                        context="{'group_by': 'team_id'}"/>

                <filter string="Product"
                        name="group_product"
                        context="{'group_by': 'product_id'}"/>

                <filter string="Invoice Month"
                        name="group_invoice_month"
                        context="{'group_by': 'invoice_date:month'}"/>
            </group>

        </search>
        </field>
    </record>

    <record id="action_sale_report_posted2" model="ir.actions.act_window">
        <field name="name">Sales Analysis Report By Posted Invoice</field>
        <field name="res_model">sale.report.posted</field>
        <field name="view_mode">list,graph,pivot</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="search_view_id" ref="sale_report_posted_view_search2"/>
        <field name="domain">[('state', '!=', 'cancel')]</field>
        <field name="context">{'search_default_Sales':1,'group_by':[]}</field>
       
    </record>

        <menuitem id="menu_sale_report_posted"
                name="Sales Analysis Report By Posted Invoice"
                action="action_sale_report_posted2"
                 parent="sale.menu_sale_report"
                sequence="1"/>
    </data></odoo>