<odoo>
    <data>
        <record id="account_payment_term_line_form_inherit" model="ir.ui.view">
            <field name="name">account.payment.term.line.form.inherit</field>
            <field name="model">account.payment.term.line</field>
            <field name="inherit_id" ref="account.account_payment_term_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='line_ids']/tree/field[@name='delay_type']" position="attributes">
                    <attribute name="widget">selection</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>