<odoo>
    <data>

        <record id="view_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form</field>
            <field name="model">account.move</field>
            <field eval="100" name="priority"/>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <field name="invoice_outstanding_credits_debits_widget" position="attributes">
                    <attribute name="invisible">state != 'posted'</attribute>
                </field>
                <xpath expr="//page[@id='invoice_tab']/field/list/field[@name='account_id']" position="attributes">
                    <attribute name="domain">[('deprecated', '=', False), ('company_ids', 'in', parent.company_id)]
                    </attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>