        <field name="view_id"></field> 
        <field name="search_view_id" ref="sale_report_posted_view_search2"/>
        <field name="domain">[('state', '!=', 'cancel')]</field>
        <field name="context">{'search_default_Sales':1,'group_by':[]}</field>
       
