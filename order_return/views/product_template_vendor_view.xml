<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- إضافة عمود Vendor في قائمة المنتجات بين Category و Cost -->
        <record id="product_template_tree_vendor_inherit" model="ir.ui.view">
            <field name="name">product.template.tree.vendor.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml"> 
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field
                        name="first_vendor_id"
                        string="Vendor"
                        readonly="1"
                        optional="show"
                    />
                </xpath>
            </field>
        </record>

    </data>
</odoo>
