<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="hr_leave_view_form_inherit" model="ir.ui.view">
		<field name="name">hr.leave.view.form.inherit</field>
		<field name="model">hr.leave</field>
		<field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager" />
		<field name="arch" type="xml">
			<xpath expr="//field[@name='name']" position="before">
				<field name="is_lost" widget="boolean_toggle"/>
				<field name="is_purchased" widget="boolean_toggle"/>
				<field name="is_paid" widget="boolean_toggle"/>
			</xpath>
			<xpath expr="//button[@name='action_validate']" position="after">
				<button name="open_leave_payment_wiz" string="Pay Leave" type="object" class="btn-primary" invisible="is_paid == True or is_purchased == True"/>
			</xpath>
			<xpath expr="//sheet" position="inside">
				<div name="button_box" >
					<button class="oe_stat_button" name="action_open_entry" type="object" icon="fa-money">
						<field name="move_id" widget="statinfo" string="Move"/>
					</button>
				</div>
			</xpath>
		</field>
	</record>

</odoo>
