<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_form_contract_warning" model="ir.ui.view">
        <field name="name">hr.form.contract.warning</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="contract_warning" invisible="1"/>
                <field name="contract_warning_message" invisible="1"/>
                <div class="alert alert-warning"  >
                    <field name="contract_warning_message"
                           readonly="1"
                         />
                </div>
            </xpath>
        </field>
    </record>

</odoo>