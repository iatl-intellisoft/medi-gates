<odoo>
    <data>

        <record id="res_config_settings_view_form_insurance" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.insurance.inherit</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet" position="inside">
                    <block title="تنبيه انتهاء التأمين" name="insurance_alert_setting">
                        <setting string="بريد تنبيه انتهاء التأمين"
                                 help="عناوين بريد إلكتروني (مفصولة بفاصلة) تستقبل تنبيهًا يوميًا بالموظفين الذين تنتهي صلاحية تأمينهم خلال 30 يومًا أو أقل. إن تُرك فارغًا يُستخدم بريد الشركة.">
                            <field name="hr_insurance_alert_emails" placeholder="hr@company.com, manager@company.com"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
