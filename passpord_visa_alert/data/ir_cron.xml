<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_passport_expiry_alert" model="ir.cron">
        <field name="name">Passport Expiry Alert</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model.cron_passport_expiry_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field> 
        <field name="active">True</field>
    </record>
    <record id="ir_cron_visa_expiry_alert123" model="ir.cron">
        <field name="name">Employee Visa Expiry Alert</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model.cron_visa_expiry_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
