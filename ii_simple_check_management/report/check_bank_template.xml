     <record id="check_print" model="ir.actions.report">
                <field name="name">Check print</field>
                <field name="model">check_followups.check_followups</field>
                <field name="report_type">qweb-pdf</field>
                <field name="report_name">ii_simple_check_management.check_bank_template1</field>
                <field name="report_file">ii_simple_check_management.check_bank_template1</field>
                <field name="binding_model_id" ref="model_check_followups_check_followups"/>
                <field name="binding_type">report</field>
        </record>
        
    <record id="Check_Page_Format" model="report.paperformat">
        <field name="name">Check Page Format</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">170</field>
        <field name="page_width">85</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
