    <template id="check_bank_template1">
		<t t-call="web.basic_layout">
                <div class="page" style="margin-left: -15px;">
                    <div t-att-style="'transform-origin:0% 100%;-webkit-transform:rotatez(90deg);position:absolute;
                  top:43mm;left:-25mm;width: 170mm;height: 85mm;font-size:' + str(font_size or 12) + 'px;'">



                        <div t-att-style="'position:absolute;left:' + str(x_amount_word or '0mm') + 
                 ';top:' + str(y_amount_word or '0mm') + 
                 ';width:' + str(money_text_width or '100mm') + 
                 ';height:' + str(money_text_height or '10mm') + ';'">
                            <div>
                                <span style="font-family: Courier New, Courier;" t-esc="Amount_in_text"/>
                            </div>
                        </div>

                        <div t-att-style="'position:absolute;left:' + str(x_date or '0mm') + ';top:' + str(y_date or '0mm') + ';'">
                            <div style="width:35mm;">
                                <span t-esc="Date"/>
                            </div>
                        </div>

<div t-att-style="'position:absolute;left:' + str(x_amount or '0mm') + ';top:' + str(y_amount or '0mm') + ';'">
                            <div>***<span t-esc="'{:,}'.format(docs.amount)"/></div>
                        </div>

<div t-att-style="'position:absolute;left:' + str(x_partner or '0mm') +
                 ';top:' + str(y_partner or '0mm') +
                 ';width:' + str(account_holder_width or '100mm') + ';'">
                            <div>
                               <!-- <span t-esc="docs.beneficiary" style="font-family:courier;"/>-->
                            </div>
                        </div>

                    </div>
                </div>
            </t>
    </template>
    
