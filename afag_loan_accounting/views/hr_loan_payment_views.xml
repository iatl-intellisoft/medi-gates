<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_loan_payment_view_form" model="ir.ui.view">
        <field name="name">hr.loan.payment.view.form</field>
        <field name="model">hr.loan.payment</field>
        <field name="arch" type="xml">
            <form string="Loan Payment">
                <header>
                    <field name="state" widget="statusbar"
                           />
                <button name="action_confirm" type="object"
                            string="Confirm"
                            invisible="state != 'draft'"
                            class="oe_highlight"
                />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group col="4">
                            <field name="employee_id" required="1"/>
                            <field name="loan_id" domain="[('employee_id', '=', employee_id),('balance_amount', '>', 0)]" required="1"/>
                            <field name="loan_amount"/>
                            <field name="loan_remaining"/>
                        </group>
                        <group>
                            <field name="journal_id" domain="[('type', 'in', ('bank','cash'))]"/>
                            <field name="move_id" readonly="1" force_save="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_loan_payment_view_tree" model="ir.ui.view">
        <field name="name">hr.loan.payment.view.tree</field>
        <field name="model">hr.loan.payment</field>
        <field name="arch" type="xml">
            <list string="Loan Payment">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="loan_amount"/>
                <field name="loan_remaining"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="hr_loan_payment_act_window" model="ir.actions.act_window">
        <field name="name">Loan Payment</field>
        <field name="res_model">hr.loan.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Loan Payment" id="loan_payment_menu_item" parent="afag_loan.hr_loan_menu_root"  action="hr_loan_payment_act_window" sequence="1"/>

</odoo>