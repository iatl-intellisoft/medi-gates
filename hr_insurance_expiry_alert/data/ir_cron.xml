<odoo>
    <data noupdate="1">

        <record id="ir_cron_check_insurance_expiry" model="ir.cron">
            <field name="name">تنبيه انتهاء صلاحية تأمين الموظفين</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_insurance_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 07:00:00')"/>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
